<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
    import { getAuth, onAuthStateChanged, createUserWithEmailAndPassword } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";
    import { getFirestore, collection, onSnapshot, doc, getDoc, setDoc, deleteDoc } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

    // Credenciales de Firebase (Mantener tal cual)
    const firebaseConfig = {
        apiKey: "AIzaSyA2eMtX0I2u1iKdtHjNisMrqVSlpJbzHNI",
        authDomain: "ucmi-13796634.firebaseapp.com",
        projectId: "ucmi-13796634",
        storageBucket: "ucmi-13796634.firebasestorage.app",
        messagingSenderId: "1090719609536",
        appId: "1:1090719609536:web:8d7f269d991d8dc3c6b325"
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);
    const auth = getAuth(app);
    const MI_UID_MAESTRO = "m56REyF19sOsC6BE5sJdJG6eR863";

    // SEGURIDAD: Solo tú pasas
    onAuthStateChanged(auth, (user) => {
        if (!user || user.uid !== MI_UID_MAESTRO) {
            window.location.href = "index.html";
        }
    });

    let currentSolicitud = null;
    let filtroActual = "Todos";

    document.getElementById('selectorFiltro').addEventListener('change', (e) => {
        filtroActual = e.target.value;
        renderTable(); // Recargar tabla con filtro
    });

    // Función para renderizar la tabla principal
    function renderTable() {
        onSnapshot(collection(db, "postulaciones"), (snapshot) => {
            const tbody = document.getElementById('listaMaestra');
            tbody.innerHTML = '';
            let counts = { "Academia": 0, "Profesor embajador": 0, "Profesor asociado": 0, "Estudiante autodidacta": 0 };

            snapshot.forEach((d) => {
                const data = d.data();
                const id = d.id;
                const perfil = data.tipoSolicitante || "Pendiente";
                if(counts[perfil] !== undefined) counts[perfil]++;

                if (filtroActual === "Todos" || perfil === filtroActual) {
                    const colorClass = perfil.includes("Academia") ? "bg-academia" : 
                                       perfil.includes("embajador") ? "bg-embajador" :
                                       perfil.includes("asociado") ? "bg-socio" : "bg-alumno";

                    // Determinar el nombre a mostrar (Entidad o Persona)
                    const nombreMostrar = data.entidad && data.entidad !== "N/A" ? data.entidad : data.nombreResponsable;

                    tbody.innerHTML += `
                        <tr class="border-bottom">
                            <td>
                                <div class="fw-bold text-dark">${nombreMostrar}</div>
                                <div class="small text-muted">${data.email}</div>
                            </td>
                            <td><span class="badge-perfil ${colorClass} text-white">${perfil}</span></td>
                            <td class="small">${data.ubicacion || 'No especificada'}
